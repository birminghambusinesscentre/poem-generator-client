# Poem-generation provider keys — used server-side only, never exposed to the
# browser. Copy this file to .env.local and fill in your keys.
#
# The server tries Pollinations first, then falls back to Groq. A provider is
# skipped if its key is left blank.

# Primary provider — https://pollinations.ai
POLLINATIONS_API_KEY=

# Fallback provider — https://console.groq.com/keys
GROQ_API_KEY=

# Cloudinary upload storage for completed photo-and-poem submissions.
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name
CLOUDINARY_UPLOAD_FOLDER=poem-generator-submissions
